# Function to detect stable zones using a rolling standard deviation
filter_stable_regions <- function(df, window_size = 10, threshold = 1) {
df$rolling_sd <- zoo::rollapply(df$Output, width = window_size, FUN = sd, fill = NA, align = "center")
stable_df <- df[which(df$rolling_sd < threshold), ]
return(stable_df)
}
# Perform linear regression
fit <- lm(Output ~ Input, data = stable_data)
