digraph "CNC" {

  # STATES
  # marking entry and exit points is important
  # gv_fsm --cpp -k stop -p CNCPP -o src/fsm src/fsm.dot  
  # it is mandatory that the init state has only outputs and no inputs
  # always check the states described in the output

  init [peripheries=2]   
  idle
  load_block
  no_motion
  rapid_motion
  interp_motion
  stop [peripheries=2]
  go_to_zero

  # TRANSITIONS 
  init -> idle
  init -> stop
  idle -> idle

  idle -> load_block                [label = "reset"]

  load_block -> no_motion
  no_motion -> load_block

  load_block -> rapid_motion        [label = "begin_rapid"]
  rapid_motion -> rapid_motion
  rapid_motion -> load_block        [label = "end_rapid"]

  load_block -> interp_motion       [label = "begin_interp"]
  interp_motion -> interp_motion
  interp_motion -> load_block       [label = "end_interp"]

  # when there are no more blocks, we go back to idle
  load_block -> idle
  idle -> stop
  idle -> go_to_zero                [label = "begin_zero"]
  go_to_zero -> go_to_zero
  go_to_zero -> idle                [label = "end_zero"]


}